---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogPostCard from '../../../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, type CategoryKey } from '../../../lib/constants';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const allPosts = await getCollection('blog');
  const categories = Object.keys(CATEGORIES) as CategoryKey[];

  return categories.map((category) => ({
    params: { category },
    props: {
      posts: allPosts
        .filter((post) => post.data.category === category && !post.data.draft)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
      categoryInfo: CATEGORIES[category],
    },
  }));
}) satisfies GetStaticPaths;

const { category } = Astro.params;
const { posts, categoryInfo } = Astro.props;

const categoryEntries = Object.entries(CATEGORIES) as [CategoryKey, (typeof CATEGORIES)[CategoryKey]][];
---

<BaseLayout title={categoryInfo.label} description={categoryInfo.description}>
  <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12">
    <h1 class="text-3xl font-bold text-zinc-900 dark:text-zinc-100 sm:text-4xl">
      {categoryInfo.label}
    </h1>
    <p class="mt-2 text-zinc-600 dark:text-zinc-400">
      {categoryInfo.description}
    </p>

    <!-- Category filters -->
    <div class="mt-6 flex flex-wrap gap-2">
      <a
        href="/blog"
        class="inline-flex items-center rounded-full border border-zinc-200 px-3 py-1 text-sm font-medium text-zinc-600 transition-colors hover:border-cyan-500/30 hover:text-cyan-600 dark:border-zinc-700 dark:text-zinc-400 dark:hover:border-cyan-400/30 dark:hover:text-cyan-400"
      >
        Все
      </a>
      {categoryEntries.map(([key, cat]) => (
        <a
          href={`/blog/category/${key}`}
          class:list={[
            'inline-flex items-center rounded-full border px-3 py-1 text-sm font-medium transition-colors',
            key === category
              ? 'border-cyan-500/30 bg-cyan-500/10 text-cyan-600 dark:text-cyan-400'
              : 'border-zinc-200 text-zinc-600 hover:border-cyan-500/30 hover:text-cyan-600 dark:border-zinc-700 dark:text-zinc-400 dark:hover:border-cyan-400/30 dark:hover:text-cyan-400',
          ]}
        >
          {cat.label}
        </a>
      ))}
    </div>

    {posts.length > 0 ? (
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => <BlogPostCard post={post} />)}
      </div>
    ) : (
      <p class="mt-12 text-center text-zinc-500 dark:text-zinc-400">
        Пока нет статей в этой категории.
      </p>
    )}
  </div>
</BaseLayout>
