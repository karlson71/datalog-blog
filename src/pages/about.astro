---
import PageLayout from '../layouts/PageLayout.astro';
import TelegramCTA from '../components/TelegramCTA.astro';
import { TELEGRAM_CHANNEL_URL } from '../lib/constants';

const skills = [
  { name: 'SQL', detail: 'ClickHouse, PostgreSQL, BigQuery' },
  { name: 'Яндекс Метрика', detail: 'Цели, сегменты, ecommerce, API' },
  { name: 'DataLens', detail: 'Дашборды, датасеты, визуализация' },
  { name: 'Сквозная аналитика', detail: 'Атрибуция, маппинг, воронки' },
  { name: 'Google Analytics', detail: 'GA4, GTM, Looker Studio' },
  { name: 'Python', detail: 'pandas, визуализация, автоматизация' },
];
---

<PageLayout title="О проекте" description="Даталог — блог о веб-аналитике, SQL и данных. Практические разборы без воды.">
  <article>
    <h1 class="text-3xl font-bold text-zinc-900 dark:text-zinc-100 sm:text-4xl">
      О проекте
    </h1>

    <div class="mt-8 space-y-6 text-zinc-600 dark:text-zinc-400">
      <p class="text-lg">
        Даталог — блог для тех, кто работает с данными и хочет делать это лучше. Без воды, без теории ради теории — только то, что реально используется в работе.
      </p>

      <p>
        Здесь разбираю SQL-запросы, настройку аналитики, построение дашбордов и сквозную аналитику. Всё на реальных примерах из маркетинговой аналитики — с кодом, скриншотами и объяснением логики.
      </p>

      <p>
        Если ты аналитик, маркетолог или просто работаешь с данными — тебе сюда. Разберёмся вместе.
      </p>
    </div>

    <!-- Skills -->
    <section class="mt-12">
      <h2 class="text-xl font-bold text-zinc-900 dark:text-zinc-100">
        Инструменты и навыки
      </h2>
      <div class="mt-6 grid gap-3 sm:grid-cols-2">
        {skills.map((skill) => (
          <div class="rounded-xl border border-zinc-200 bg-zinc-50 p-4 dark:border-zinc-800 dark:bg-zinc-900">
            <p class="font-medium text-zinc-900 dark:text-zinc-100">{skill.name}</p>
            <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">{skill.detail}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Contact -->
    <section class="mt-12">
      <h2 class="text-xl font-bold text-zinc-900 dark:text-zinc-100">
        Связаться
      </h2>
      <p class="mt-4 text-zinc-600 dark:text-zinc-400">
        Лучший способ связаться со мной — написать в Telegram. Там же публикую короткие заметки, SQL-задачки и анонсы новых статей.
      </p>
      <a
        href={TELEGRAM_CHANNEL_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-flex items-center gap-2 rounded-xl bg-cyan-500 px-6 py-3 text-base font-medium text-white transition-all hover:bg-cyan-600 hover:shadow-lg hover:shadow-cyan-500/25 dark:bg-cyan-400 dark:text-zinc-950 dark:hover:bg-cyan-300"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
        </svg>
        Telegram-канал
      </a>
    </section>
  </article>
</PageLayout>
