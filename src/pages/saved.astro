---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CATEGORIES } from '../lib/constants';
---

<BaseLayout title="Сохранённые статьи" description="Ваши сохранённые статьи для чтения позже.">
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
    <div class="flex items-center justify-between">
      <h1 class="text-3xl font-bold text-zinc-900 dark:text-zinc-100 sm:text-4xl">
        Сохранённые
      </h1>
      <button
        id="clear-all-btn"
        type="button"
        class="hidden rounded-lg border border-zinc-200 px-4 py-2 text-sm font-medium text-zinc-600 transition-colors hover:border-red-300 hover:bg-red-50 hover:text-red-600 dark:border-zinc-700 dark:text-zinc-400 dark:hover:border-red-500/30 dark:hover:bg-red-500/10 dark:hover:text-red-400"
      >
        Очистить всё
      </button>
    </div>

    <!-- Empty state -->
    <div id="saved-empty" class="mt-16 hidden text-center">
      <svg class="mx-auto h-16 w-16 text-zinc-300 dark:text-zinc-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
      </svg>
      <p class="mt-4 text-lg text-zinc-500 dark:text-zinc-400">
        Нет сохранённых статей.
      </p>
      <p class="mt-1 text-zinc-400 dark:text-zinc-500">
        Начните читать и сохраняйте интересное!
      </p>
      <a
        href="/blog"
        class="mt-6 inline-flex items-center gap-2 rounded-xl bg-cyan-500 px-6 py-3 text-base font-medium text-white transition-all hover:bg-cyan-600 hover:shadow-lg hover:shadow-cyan-500/25 dark:bg-cyan-400 dark:text-zinc-950 dark:hover:bg-cyan-300"
      >
        Перейти к статьям
      </a>
    </div>

    <!-- Bookmarks list -->
    <div id="saved-list" class="mt-8 hidden space-y-4"></div>
  </div>
</BaseLayout>

<script define:vars={{ CATEGORIES }}>
  const categoriesMap = CATEGORIES;

  function initSavedPage() {
    const STORAGE_KEY = 'datalog_bookmarks';
    const listEl = document.getElementById('saved-list');
    const emptyEl = document.getElementById('saved-empty');
    const clearBtn = document.getElementById('clear-all-btn');
    if (!listEl || !emptyEl || !clearBtn) return;

    function render() {
      let bookmarks = {};
      try {
        bookmarks = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
      } catch {
        bookmarks = {};
      }

      const entries = Object.entries(bookmarks).sort(
        (a, b) => new Date(b[1].savedAt).getTime() - new Date(a[1].savedAt).getTime()
      );

      if (entries.length === 0) {
        listEl.classList.add('hidden');
        emptyEl.classList.remove('hidden');
        clearBtn.classList.add('hidden');
        return;
      }

      emptyEl.classList.add('hidden');
      listEl.classList.remove('hidden');
      clearBtn.classList.remove('hidden');

      listEl.innerHTML = entries
        .map(([slug, data]) => {
          const catInfo = categoriesMap[data.category];
          const catLabel = catInfo ? catInfo.label : data.category;
          return `<article class="group relative rounded-xl border border-zinc-200 bg-white p-5 transition-all duration-200 hover:-translate-y-0.5 hover:border-cyan-500/30 hover:shadow-lg hover:shadow-cyan-500/5 dark:border-zinc-800 dark:bg-zinc-900 dark:hover:border-cyan-400/30 dark:hover:shadow-cyan-400/5 sm:p-6">
            <a href="/blog/${slug}/" class="block">
              <span class="inline-flex items-center rounded-full border border-zinc-200 bg-zinc-100 px-2 py-0.5 text-xs font-medium text-zinc-600 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-400">${catLabel}</span>
              <h3 class="mt-3 text-lg font-semibold text-zinc-900 transition-colors group-hover:text-cyan-600 dark:text-zinc-100 dark:group-hover:text-cyan-400 sm:text-xl">${data.title}</h3>
              <p class="mt-2 line-clamp-2 text-sm text-zinc-600 dark:text-zinc-400 sm:text-base">${data.description}</p>
            </a>
            <button
              type="button"
              data-remove-slug="${slug}"
              aria-label="Убрать из сохранённых"
              class="absolute top-4 right-4 flex h-8 w-8 items-center justify-center rounded-lg text-zinc-400 transition-colors hover:bg-red-50 hover:text-red-500 dark:text-zinc-500 dark:hover:bg-red-500/10 dark:hover:text-red-400"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </article>`;
        })
        .join('');

      // Bind remove buttons
      listEl.querySelectorAll('[data-remove-slug]').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const slug = btn.getAttribute('data-remove-slug');
          const current = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
          delete current[slug];
          localStorage.setItem(STORAGE_KEY, JSON.stringify(current));
          render();
        });
      });
    }

    clearBtn.addEventListener('click', () => {
      localStorage.removeItem(STORAGE_KEY);
      render();
    });

    render();
  }

  initSavedPage();
  document.addEventListener('astro:after-swap', initSavedPage);
</script>
