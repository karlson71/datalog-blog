---
---

<!-- Text Selection Share Toolbar -->
<div
  id="text-share-toolbar"
  class="fixed z-50 hidden items-center gap-1 rounded-lg border border-zinc-200 bg-white px-2 py-1.5 shadow-xl dark:border-zinc-700 dark:bg-zinc-800"
  style="top: 0; left: 0;"
>
  <button
    id="share-telegram"
    class="flex h-7 w-7 items-center justify-center rounded-md text-zinc-500 transition-colors hover:bg-cyan-50 hover:text-cyan-600 dark:text-zinc-400 dark:hover:bg-cyan-900/30 dark:hover:text-cyan-400"
    title="Поделиться в Telegram"
  >
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
      <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
    </svg>
  </button>
  <button
    id="share-copy"
    class="flex h-7 w-7 items-center justify-center rounded-md text-zinc-500 transition-colors hover:bg-cyan-50 hover:text-cyan-600 dark:text-zinc-400 dark:hover:bg-cyan-900/30 dark:hover:text-cyan-400"
    title="Скопировать цитату"
  >
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
      <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
    </svg>
  </button>
</div>

<script>
  function initTextShare() {
    const toolbar = document.getElementById('text-share-toolbar');
    const telegramBtn = document.getElementById('share-telegram');
    const copyBtn = document.getElementById('share-copy');
    if (!toolbar || !telegramBtn || !copyBtn) return;

    let selectedText = '';

    function hideToolbar() {
      toolbar.classList.add('hidden');
      toolbar.classList.remove('flex');
    }

    function showToolbar(x: number, y: number) {
      toolbar.style.left = `${Math.min(x, window.innerWidth - 100)}px`;
      toolbar.style.top = `${y - 45}px`;
      toolbar.classList.remove('hidden');
      toolbar.classList.add('flex');
    }

    document.addEventListener('mouseup', (e) => {
      const selection = window.getSelection();
      const text = selection?.toString().trim() || '';

      // Only show in article content
      const target = e.target as HTMLElement;
      if (!target.closest('.prose') && !target.closest('article')) {
        hideToolbar();
        return;
      }

      if (text.length > 10 && text.length < 500) {
        selectedText = text;
        const range = selection!.getRangeAt(0);
        const rect = range.getBoundingClientRect();
        showToolbar(
          rect.left + rect.width / 2 - 35,
          rect.top + window.scrollY
        );
      } else {
        hideToolbar();
      }
    });

    // Hide on click outside
    document.addEventListener('mousedown', (e) => {
      if (!(e.target as HTMLElement).closest('#text-share-toolbar')) {
        setTimeout(hideToolbar, 100);
      }
    });

    telegramBtn.addEventListener('click', () => {
      const url = window.location.href;
      const quote = `«${selectedText}»\n\n${url}`;
      window.open(
        `https://t.me/share/url?url=${encodeURIComponent(url)}&text=${encodeURIComponent(quote)}`,
        '_blank',
        'width=600,height=400'
      );
      hideToolbar();
    });

    copyBtn.addEventListener('click', () => {
      const url = window.location.href;
      const quote = `«${selectedText}»\n— ${url}`;
      navigator.clipboard.writeText(quote).then(() => {
        copyBtn.innerHTML = '<svg class="h-4 w-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>';
        setTimeout(() => {
          copyBtn.innerHTML = '<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>';
          hideToolbar();
        }, 1500);
      });
    });
  }

  initTextShare();
  document.addEventListener('astro:after-swap', initTextShare);
</script>
