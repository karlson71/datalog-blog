---
interface Props {
  readingTime?: string;
}

const { readingTime } = Astro.props;
---

<!-- Progress bar (clickable → scroll to top) -->
<div
  id="reading-progress"
  class="fixed left-0 top-0 z-50 h-[3px] cursor-pointer bg-gradient-to-r from-cyan-400 via-cyan-500 to-teal-400 shadow-[0_0_8px_rgba(34,211,238,0.4)] transition-[width] duration-150 ease-out"
  style="width: 0%"
  role="progressbar"
  aria-label="Прогресс чтения"
/>

<!-- Time remaining badge -->
{readingTime && (
  <div
    id="reading-time-badge"
    class="fixed right-3 top-3 z-50 hidden items-center gap-1 rounded-full border border-zinc-300/80 bg-white/80 px-2 py-1 text-[11px] font-medium text-zinc-600 shadow-md backdrop-blur-md transition-all duration-300 sm:right-6 sm:gap-1.5 sm:px-3 sm:py-1.5 sm:text-sm dark:border-zinc-600/50 dark:bg-zinc-900/80 dark:text-zinc-300"
    data-total-minutes={readingTime}
  >
    <svg class="h-3 w-3 text-cyan-500 sm:h-3.5 sm:w-3.5 dark:text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="10" />
      <path d="M12 6v6l4 2" />
    </svg>
    <span id="time-remaining-text"></span>
  </div>
)}

<script>
  function initProgress() {
    const bar = document.getElementById('reading-progress');
    const badge = document.getElementById('reading-time-badge');
    const timeText = document.getElementById('time-remaining-text');
    if (!bar) return;

    // Click progress bar → scroll to top
    bar.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    const totalMinutesStr = badge?.getAttribute('data-total-minutes') || '';
    const totalMinutes = parseInt(totalMinutesStr.replace(/\D/g, ''), 10) || 0;
    const isMobile = window.innerWidth < 640;

    let ticking = false;

    function updateProgress() {
      const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = scrollHeight > 0 ? window.scrollY / scrollHeight : 0;
      const scrolled = Math.min(progress * 100, 100);
      bar!.style.width = `${scrolled}%`;

      if (badge && timeText && totalMinutes > 0) {
        if (progress < 0.03 || progress >= 0.97) {
          badge.classList.add('hidden');
          badge.classList.remove('flex');
        } else {
          badge.classList.remove('hidden');
          badge.classList.add('flex');
          const remaining = Math.max(1, Math.ceil(totalMinutes * (1 - progress)));
          timeText.textContent = isMobile ? `~${remaining}м` : `~${remaining} мин`;
        }
      }

      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateProgress);
        ticking = true;
      }
    });
    updateProgress();
  }

  initProgress();
  document.addEventListener('astro:after-swap', initProgress);
</script>
