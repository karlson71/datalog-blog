---
import PostMeta from './PostMeta.astro';
import BookmarkButton from './BookmarkButton.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, category, difficulty } = post.data;
---

<article class="group relative" data-post-slug={post.id}>
  <a href={`/blog/${post.id}/`} class="block">
    <div class="rounded-xl border border-zinc-200 bg-white p-5 transition-all duration-200 hover:-translate-y-0.5 hover:border-cyan-500/30 hover:shadow-lg hover:shadow-cyan-500/5 dark:border-zinc-800 dark:bg-zinc-900 dark:hover:border-cyan-400/30 dark:hover:shadow-cyan-400/5 sm:p-6">
      <PostMeta pubDate={pubDate} category={category} difficulty={difficulty} linked={false} />
      <h3 class="mt-3 pr-8 text-lg font-semibold text-zinc-900 transition-colors group-hover:text-cyan-600 dark:text-zinc-100 dark:group-hover:text-cyan-400 sm:text-xl">
        {title}
      </h3>
      <p class="mt-2 line-clamp-2 text-sm text-zinc-600 dark:text-zinc-400 sm:text-base">
        {description}
      </p>
      <!-- Read indicator (shown via JS) -->
      <div class="read-badge mt-3 hidden items-center gap-1 text-xs font-medium text-emerald-500 dark:text-emerald-400">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        <span>Прочитано</span>
      </div>
    </div>
  </a>
  <div class="absolute top-4 right-4 z-10">
    <BookmarkButton slug={post.id} title={title} description={description} category={category} size="sm" />
  </div>
</article>

<script>
  function initReadBadges() {
    const STORAGE_KEY = 'datalog_read_posts';
    try {
      const readPosts: string[] = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      document.querySelectorAll<HTMLElement>('[data-post-slug]').forEach((card) => {
        const slug = card.getAttribute('data-post-slug');
        const badge = card.querySelector('.read-badge') as HTMLElement;
        if (slug && readPosts.includes(slug) && badge) {
          badge.classList.remove('hidden');
          badge.classList.add('flex');
        }
      });
    } catch { /* ignore */ }
  }

  initReadBadges();
  document.addEventListener('astro:after-swap', initReadBadges);
</script>
