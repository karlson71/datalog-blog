---
interface Props {
  slug: string;
  title: string;
  description: string;
  category: string;
  size?: 'sm' | 'md';
}

const { slug, title, description, category, size = 'md' } = Astro.props;
---

<bookmark-btn
  data-slug={slug}
  data-title={title}
  data-description={description}
  data-category={category}
  class="relative"
>
  <button
    type="button"
    aria-label="Сохранить статью"
    class:list={[
      'bookmark-toggle group/bm flex items-center justify-center rounded-lg transition-all duration-200 active:scale-90',
      size === 'sm'
        ? 'h-8 w-8'
        : 'h-9 w-9 border border-zinc-200 hover:border-cyan-500/30 hover:bg-cyan-50 dark:border-zinc-700 dark:hover:border-cyan-400/30 dark:hover:bg-cyan-400/10',
    ]}
  >
    <!-- Outline icon (not saved) -->
    <svg
      class="bookmark-icon-outline h-5 w-5 text-zinc-400 transition-colors group-hover/bm:text-cyan-500 dark:text-zinc-500 dark:group-hover/bm:text-cyan-400"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
    </svg>
    <!-- Filled icon (saved) -->
    <svg
      class="bookmark-icon-filled hidden h-5 w-5 text-cyan-500 dark:text-cyan-400"
      viewBox="0 0 24 24"
      fill="currentColor"
    >
      <path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
    </svg>
  </button>

  <!-- Toast -->
  <span class="bookmark-toast pointer-events-none absolute top-full left-1/2 z-50 mt-2 -translate-x-1/2 whitespace-nowrap rounded-lg bg-zinc-800 px-3 py-1.5 text-xs font-medium text-zinc-100 opacity-0 shadow-lg transition-all duration-300 dark:bg-zinc-700">
  </span>
</bookmark-btn>

<script>
  function initBookmarks() {
    const STORAGE_KEY = 'datalog_bookmarks';

    function getBookmarks(): Record<string, { title: string; description: string; category: string; savedAt: string }> {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
      } catch {
        return {};
      }
    }

    function saveBookmarks(bookmarks: Record<string, any>) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(bookmarks));
    }

    document.querySelectorAll('bookmark-btn').forEach((el) => {
      const slug = el.getAttribute('data-slug')!;
      const title = el.getAttribute('data-title')!;
      const description = el.getAttribute('data-description')!;
      const category = el.getAttribute('data-category')!;
      const btn = el.querySelector('.bookmark-toggle') as HTMLButtonElement;
      const iconOutline = el.querySelector('.bookmark-icon-outline') as SVGElement;
      const iconFilled = el.querySelector('.bookmark-icon-filled') as SVGElement;
      const toast = el.querySelector('.bookmark-toast') as HTMLElement;

      function updateUI(saved: boolean) {
        if (saved) {
          iconOutline.classList.add('hidden');
          iconFilled.classList.remove('hidden');
          btn.setAttribute('aria-label', 'Убрать из сохранённых');
        } else {
          iconOutline.classList.remove('hidden');
          iconFilled.classList.add('hidden');
          btn.setAttribute('aria-label', 'Сохранить статью');
        }
      }

      function showToast(text: string) {
        toast.textContent = text;
        toast.classList.remove('opacity-0');
        toast.classList.add('opacity-100');
        setTimeout(() => {
          toast.classList.remove('opacity-100');
          toast.classList.add('opacity-0');
        }, 1500);
      }

      // Set initial state
      const bookmarks = getBookmarks();
      updateUI(slug in bookmarks);

      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const current = getBookmarks();
        if (slug in current) {
          delete current[slug];
          saveBookmarks(current);
          updateUI(false);
          showToast('Удалено из сохранённых');
        } else {
          current[slug] = { title, description, category, savedAt: new Date().toISOString() };
          saveBookmarks(current);
          updateUI(true);
          showToast('Сохранено!');
        }
      });
    });
  }

  initBookmarks();
  document.addEventListener('astro:after-swap', initBookmarks);
</script>
