---
interface Props {
  src?: string;
  alt: string;
  caption?: string;
  invert?: boolean;
}

const { src, alt, caption, invert = false } = Astro.props;
const uniqueId = `diagram-${Math.random().toString(36).slice(2, 9)}`;
---

<figure class="not-prose my-8 flex flex-col items-center">
  <div
    class:list={[
      'diagram-container relative max-w-full cursor-zoom-in overflow-hidden rounded-xl border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900 sm:p-6',
      { 'diagram-invert': invert },
    ]}
    data-dialog-id={uniqueId}
    role="button"
    tabindex="0"
    aria-label={`Увеличить: ${alt}`}
  >
    {src ? (
      <img
        src={src}
        alt={alt}
        class:list={[
          'mx-auto max-h-[500px] w-auto max-w-full object-contain',
          { 'dark:invert dark:brightness-90 dark:contrast-110': invert },
        ]}
        loading="lazy"
      />
    ) : (
      <div
        class:list={[
          'diagram-slot mx-auto flex items-center justify-center',
          { 'dark:invert dark:brightness-90 dark:contrast-110': invert },
        ]}
      >
        <slot />
      </div>
    )}

    <!-- Zoom hint -->
    <div class="absolute bottom-2 right-2 flex items-center gap-1 rounded-md bg-zinc-900/70 px-2 py-1 text-xs text-zinc-300 opacity-0 transition-opacity group-hover:opacity-100 dark:bg-zinc-100/70 dark:text-zinc-700 sm:bottom-3 sm:right-3">
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607ZM10.5 7.5v6m3-3h-6" />
      </svg>
      Увеличить
    </div>
  </div>

  {caption && (
    <figcaption class="mt-3 text-center text-sm italic text-zinc-500 dark:text-zinc-400">
      {caption}
    </figcaption>
  )}

  <!-- Lightbox dialog -->
  <dialog
    id={uniqueId}
    class="diagram-dialog m-0 h-full max-h-full w-full max-w-full border-0 bg-black/90 p-4 backdrop:bg-transparent sm:p-8"
  >
    <div class="flex h-full w-full flex-col items-center justify-center">
      <button
        class="diagram-dialog-close absolute right-4 top-4 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-zinc-800 text-zinc-300 transition-colors hover:bg-zinc-700 hover:text-white"
        type="button"
        aria-label="Закрыть"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>

      <div class="flex max-h-[90vh] max-w-[90vw] items-center justify-center overflow-auto">
        {src ? (
          <img
            src={src}
            alt={alt}
            class:list={[
              'max-h-[85vh] max-w-full object-contain',
              { 'invert brightness-90 contrast-110': invert },
            ]}
          />
        ) : (
          <div
            class:list={[
              'diagram-slot-clone flex items-center justify-center',
              { 'invert brightness-90 contrast-110': invert },
            ]}
          >
            <slot />
          </div>
        )}
      </div>

      {caption && (
        <p class="mt-4 text-center text-sm text-zinc-400">{caption}</p>
      )}
    </div>
  </dialog>
</figure>

<style>
  .diagram-container:hover .opacity-0 {
    opacity: 1;
  }

  .diagram-dialog::backdrop {
    background: transparent;
  }

  .diagram-dialog[open] {
    animation: diagram-fade-in 0.2s ease-out;
  }

  @keyframes diagram-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>

<script>
  function initDiagrams() {
    document.querySelectorAll('.diagram-container').forEach((container) => {
      const dialogId = container.getAttribute('data-dialog-id');
      if (!dialogId) return;

      const dialog = document.getElementById(dialogId) as HTMLDialogElement | null;
      if (!dialog) return;

      function openDialog() {
        dialog!.showModal();
      }

      function closeDialog() {
        dialog!.close();
      }

      container.addEventListener('click', openDialog);
      container.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
          e.preventDefault();
          openDialog();
        }
      });

      const closeBtn = dialog.querySelector('.diagram-dialog-close');
      closeBtn?.addEventListener('click', closeDialog);

      dialog.addEventListener('click', (e) => {
        if (e.target === dialog) closeDialog();
      });

      dialog.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeDialog();
      });
    });
  }

  initDiagrams();
  document.addEventListener('astro:after-swap', initDiagrams);
</script>
