---
interface Props {
  query: string;
  setup?: string;
  title?: string;
}

const { query, setup, title } = Astro.props;
const uniqueId = `sql-playground-${Math.random().toString(36).slice(2, 9)}`;
---

<div
  class="not-prose my-8"
  id={uniqueId}
  data-default-query={query}
  data-setup={setup || ''}
>
  <sql-playground data-id={uniqueId}>
    <!-- Header -->
    {title && (
      <div class="mb-3 flex items-center gap-2">
        <svg class="h-5 w-5 text-cyan-500 dark:text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125v-3.75" />
        </svg>
        <h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100">
          {title}
        </h3>
      </div>
    )}

    <div class="overflow-hidden rounded-xl border border-zinc-200 dark:border-zinc-800">
      <!-- Editor area -->
      <div class="bg-zinc-950">
        <div class="flex items-center justify-between border-b border-zinc-800 px-4 py-2">
          <span class="text-xs font-medium text-zinc-500">SQL</span>
          <div class="flex items-center gap-2">
            <button
              type="button"
              class="sql-reset-btn rounded-md px-2.5 py-1 text-xs font-medium text-zinc-500 transition-colors hover:bg-zinc-800 hover:text-zinc-300"
            >
              Сбросить
            </button>
            <button
              type="button"
              class="sql-run-btn inline-flex items-center gap-1.5 rounded-md bg-cyan-500 px-3 py-1 text-xs font-semibold text-white shadow-sm transition-colors hover:bg-cyan-400 disabled:cursor-not-allowed disabled:opacity-50"
            >
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
              Выполнить
            </button>
          </div>
        </div>
        <textarea
          class="sql-editor block w-full resize-y bg-zinc-950 p-4 font-mono text-sm leading-relaxed text-zinc-100 placeholder-zinc-600 focus:outline-none"
          style="font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace; min-height: 80px; tab-size: 2;"
          spellcheck="false"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          placeholder="Введите SQL-запрос..."
        >{query}</textarea>
      </div>

      <!-- Results area -->
      <div class="sql-results border-t border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900">
        <!-- Loading state -->
        <div class="sql-loading flex items-center gap-2 px-4 py-3">
          <svg class="h-4 w-4 animate-spin text-cyan-500" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" />
          </svg>
          <span class="text-sm text-zinc-500 dark:text-zinc-400">Загрузка WASM...</span>
        </div>

        <!-- Error display -->
        <div class="sql-error hidden border-t border-red-500/20 bg-red-500/5 px-4 py-3">
          <div class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
            </svg>
            <pre class="sql-error-text whitespace-pre-wrap text-sm text-red-500 dark:text-red-400" style="font-family: 'JetBrains Mono', 'Fira Code', monospace;"></pre>
          </div>
        </div>

        <!-- Table output -->
        <div class="sql-table-wrap hidden overflow-x-auto">
          <table class="sql-table w-full text-left text-sm">
            <thead class="sql-thead"></thead>
            <tbody class="sql-tbody"></tbody>
          </table>
        </div>

        <!-- Empty state -->
        <div class="sql-empty hidden px-4 py-3">
          <span class="text-sm text-zinc-500 dark:text-zinc-400">Запрос выполнен. Результатов нет.</span>
        </div>
      </div>
    </div>
  </sql-playground>
</div>

<style>
  .sql-editor::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }

  .sql-editor::-webkit-scrollbar-track {
    background: transparent;
  }

  .sql-editor::-webkit-scrollbar-thumb {
    background-color: rgb(63 63 70);
    border-radius: 4px;
  }

  .sql-table-wrap::-webkit-scrollbar {
    height: 6px;
  }

  .sql-table-wrap::-webkit-scrollbar-track {
    background: transparent;
  }

  .sql-table-wrap::-webkit-scrollbar-thumb {
    background-color: rgb(161 161 170);
    border-radius: 3px;
  }

  :global(.dark) .sql-table-wrap::-webkit-scrollbar-thumb {
    background-color: rgb(63 63 70);
  }

  .sql-table thead th {
    position: sticky;
    top: 0;
    padding: 0.5rem 1rem;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
    border-bottom: 1px solid rgb(228 228 231);
    background-color: rgb(250 250 250);
    color: rgb(113 113 122);
  }

  :global(.dark) .sql-table thead th {
    border-bottom-color: rgb(39 39 42);
    background-color: rgb(24 24 27);
    color: rgb(161 161 170);
  }

  .sql-table tbody td {
    padding: 0.375rem 1rem;
    white-space: nowrap;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.8125rem;
    color: rgb(63 63 70);
  }

  :global(.dark) .sql-table tbody td {
    color: rgb(212 212 216);
  }

  .sql-table tbody tr:nth-child(even) {
    background-color: rgb(250 250 250);
  }

  :global(.dark) .sql-table tbody tr:nth-child(even) {
    background-color: rgb(24 24 27 / 0.5);
  }

  .sql-table tbody tr:hover {
    background-color: rgb(244 244 245);
  }

  :global(.dark) .sql-table tbody tr:hover {
    background-color: rgb(39 39 42 / 0.5);
  }

  .sql-table tbody td.sql-null {
    color: rgb(161 161 170);
    font-style: italic;
  }

  :global(.dark) .sql-table tbody td.sql-null {
    color: rgb(82 82 91);
  }
</style>

<script>
  const SQL_WASM_URL = 'https://cdnjs.cloudflare.com/ajax/libs/sql.js/1.11.0/sql-wasm.wasm';
  const SQL_JS_URL = 'https://cdnjs.cloudflare.com/ajax/libs/sql.js/1.11.0/sql-wasm.js';

  let sqlPromise: Promise<any> | null = null;

  function loadSqlJs(): Promise<any> {
    if (sqlPromise) return sqlPromise;
    sqlPromise = new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = SQL_JS_URL;
      script.onload = () => {
        (window as any)
          .initSqlJs({ locateFile: () => SQL_WASM_URL })
          .then(resolve)
          .catch(reject);
      };
      script.onerror = () => reject(new Error('Failed to load sql.js'));
      document.head.appendChild(script);
    });
    return sqlPromise;
  }

  class SQLPlaygroundElement extends HTMLElement {
    private db: any = null;
    private defaultQuery: string = '';

    connectedCallback() {
      const containerId = this.dataset.id;
      if (!containerId) return;

      const container = document.getElementById(containerId);
      if (!container) return;

      this.defaultQuery = container.dataset.defaultQuery || '';
      const setupSQL = container.dataset.setup || '';

      const editor = this.querySelector('.sql-editor') as HTMLTextAreaElement;
      const runBtn = this.querySelector('.sql-run-btn') as HTMLButtonElement;
      const resetBtn = this.querySelector('.sql-reset-btn') as HTMLButtonElement;
      const loadingEl = this.querySelector('.sql-loading') as HTMLElement;
      const errorEl = this.querySelector('.sql-error') as HTMLElement;
      const errorText = this.querySelector('.sql-error-text') as HTMLElement;
      const tableWrap = this.querySelector('.sql-table-wrap') as HTMLElement;
      const thead = this.querySelector('.sql-thead') as HTMLElement;
      const tbody = this.querySelector('.sql-tbody') as HTMLElement;
      const emptyEl = this.querySelector('.sql-empty') as HTMLElement;

      if (!editor || !runBtn || !resetBtn) return;

      runBtn.disabled = true;

      const hideAll = () => {
        loadingEl.classList.add('hidden');
        errorEl.classList.add('hidden');
        tableWrap.classList.add('hidden');
        emptyEl.classList.add('hidden');
      };

      const showError = (msg: string) => {
        hideAll();
        errorText.textContent = msg;
        errorEl.classList.remove('hidden');
      };

      const showResults = (columns: string[], values: any[][]) => {
        hideAll();

        if (columns.length === 0) {
          emptyEl.classList.remove('hidden');
          return;
        }

        thead.innerHTML = '<tr>' + columns.map((c) => `<th>${escapeHtml(c)}</th>`).join('') + '</tr>';

        if (values.length === 0) {
          tbody.innerHTML = `<tr><td colspan="${columns.length}" class="text-center !text-zinc-400 dark:!text-zinc-500 py-3">Пустой результат</td></tr>`;
        } else {
          tbody.innerHTML = values
            .map(
              (row) =>
                '<tr>' +
                row
                  .map((val) => {
                    if (val === null) return `<td class="sql-null">NULL</td>`;
                    return `<td>${escapeHtml(String(val))}</td>`;
                  })
                  .join('') +
                '</tr>'
            )
            .join('');
        }

        tableWrap.classList.remove('hidden');
      };

      const escapeHtml = (str: string): string => {
        const div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
      };

      const runQuery = () => {
        if (!this.db) return;
        const sql = editor.value.trim();
        if (!sql) {
          showError('Введите SQL-запрос');
          return;
        }
        try {
          const results = this.db.exec(sql);
          if (results.length === 0) {
            showResults([], []);
          } else {
            const result = results[results.length - 1];
            showResults(result.columns, result.values);
          }
        } catch (e: any) {
          showError(e.message || String(e));
        }
      };

      runBtn.addEventListener('click', runQuery);

      editor.addEventListener('keydown', (e: KeyboardEvent) => {
        if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
          e.preventDefault();
          runQuery();
        }
        // Tab inserts two spaces
        if (e.key === 'Tab') {
          e.preventDefault();
          const start = editor.selectionStart;
          const end = editor.selectionEnd;
          editor.value = editor.value.substring(0, start) + '  ' + editor.value.substring(end);
          editor.selectionStart = editor.selectionEnd = start + 2;
        }
      });

      resetBtn.addEventListener('click', () => {
        editor.value = this.defaultQuery;
        hideAll();
      });

      // Auto-resize editor
      const autoResize = () => {
        editor.style.height = 'auto';
        editor.style.height = Math.max(80, editor.scrollHeight) + 'px';
      };
      editor.addEventListener('input', autoResize);

      // Initialize sql.js
      loadSqlJs()
        .then((SQL: any) => {
          this.db = new SQL.Database();
          if (setupSQL) {
            try {
              this.db.run(setupSQL);
            } catch (e: any) {
              showError('Ошибка инициализации: ' + (e.message || String(e)));
              return;
            }
          }
          hideAll();
          runBtn.disabled = false;
          autoResize();
        })
        .catch((e: any) => {
          showError('Не удалось загрузить SQL.js: ' + (e.message || String(e)));
        });
    }

    disconnectedCallback() {
      if (this.db) {
        this.db.close();
        this.db = null;
      }
    }
  }

  function initSQLPlaygrounds() {
    if (!customElements.get('sql-playground')) {
      customElements.define('sql-playground', SQLPlaygroundElement);
    }
  }

  initSQLPlaygrounds();
  document.addEventListener('astro:after-swap', () => {
    // Reset the WASM promise on page swap to allow re-init
    sqlPromise = null;
    initSQLPlaygrounds();
  });
</script>
