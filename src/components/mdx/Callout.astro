---
interface Props {
  type?: 'info' | 'warning' | 'tip' | 'danger';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const config: Record<string, { border: string; bg: string; icon: string; text: string; defaultTitle: string }> = {
  info: {
    border: 'border-cyan-500/30',
    bg: 'bg-cyan-500/5',
    icon: 'text-cyan-500 dark:text-cyan-400',
    text: 'text-cyan-900 dark:text-cyan-200',
    defaultTitle: 'Информация',
  },
  warning: {
    border: 'border-amber-500/30',
    bg: 'bg-amber-500/5',
    icon: 'text-amber-500 dark:text-amber-400',
    text: 'text-amber-900 dark:text-amber-200',
    defaultTitle: 'Внимание',
  },
  tip: {
    border: 'border-emerald-500/30',
    bg: 'bg-emerald-500/5',
    icon: 'text-emerald-500 dark:text-emerald-400',
    text: 'text-emerald-900 dark:text-emerald-200',
    defaultTitle: 'Совет',
  },
  danger: {
    border: 'border-red-500/30',
    bg: 'bg-red-500/5',
    icon: 'text-red-500 dark:text-red-400',
    text: 'text-red-900 dark:text-red-200',
    defaultTitle: 'Важно',
  },
};

const c = config[type];
const displayTitle = title || c.defaultTitle;
---

<aside
  class:list={[
    'not-prose my-8 rounded-xl border-l-4 p-4 sm:p-5',
    c.border,
    c.bg,
  ]}
  role="note"
>
  <div class="flex items-start gap-3">
    <!-- Icon -->
    <span class:list={['mt-0.5 shrink-0', c.icon]}>
      {type === 'info' && (
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
        </svg>
      )}
      {type === 'warning' && (
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
        </svg>
      )}
      {type === 'tip' && (
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
        </svg>
      )}
      {type === 'danger' && (
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285ZM12 15.75h.008v.008H12v-.008Z" />
        </svg>
      )}
    </span>

    <div class="min-w-0 flex-1">
      <p class:list={['text-sm font-semibold', c.text]}>
        {displayTitle}
      </p>
      <div class="mt-1.5 text-sm text-zinc-700 dark:text-zinc-300 [&>p]:mt-1.5 [&>p:first-child]:mt-0 [&>ul]:mt-1.5 [&>ul]:list-disc [&>ul]:pl-4 [&>ol]:mt-1.5 [&>ol]:list-decimal [&>ol]:pl-4 [&>code]:rounded [&>code]:bg-zinc-200/60 [&>code]:px-1 [&>code]:py-0.5 [&>code]:text-xs [&>code]:dark:bg-zinc-700/60">
        <slot />
      </div>
    </div>
  </div>
</aside>
