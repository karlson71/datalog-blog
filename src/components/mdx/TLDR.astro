---
---

<aside class="not-prose my-8">
  <!-- Mobile: collapsible -->
  <details class="tldr-details group rounded-xl border-l-4 border-transparent bg-cyan-50 p-4 sm:p-5 lg:hidden" open>
    <summary class="flex cursor-pointer list-none items-center gap-2 text-base font-bold text-zinc-900 [&::-webkit-details-marker]:hidden dark:text-zinc-100">
      <span class="shrink-0 text-lg">&#x26A1;</span>
      <span>Суть за 30 секунд</span>
      <svg
        class="ml-auto h-4 w-4 shrink-0 text-zinc-400 transition-transform group-open:rotate-180 dark:text-zinc-500"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
      </svg>
    </summary>
    <div class="mt-3 text-sm text-zinc-700 dark:text-zinc-300 [&>ul]:mt-1.5 [&>ul]:list-disc [&>ul]:pl-4 [&>ul]:space-y-1 [&>ol]:mt-1.5 [&>ol]:list-decimal [&>ol]:pl-4 [&>ol]:space-y-1 [&>p]:mt-1.5 [&>p:first-child]:mt-0">
      <slot />
    </div>
    <p class="mt-3 text-xs text-zinc-400 dark:text-zinc-500">Подробности ниже &#x2193;</p>
  </details>

  <!-- Desktop: always open -->
  <div class="hidden rounded-xl border-l-4 border-transparent bg-cyan-50 p-4 sm:p-5 lg:block">
    <p class="flex items-center gap-2 text-base font-bold text-zinc-900 dark:text-zinc-100">
      <span class="shrink-0 text-lg">&#x26A1;</span>
      <span>Суть за 30 секунд</span>
    </p>
    <div class="mt-3 text-sm text-zinc-700 dark:text-zinc-300 [&>ul]:mt-1.5 [&>ul]:list-disc [&>ul]:pl-4 [&>ul]:space-y-1 [&>ol]:mt-1.5 [&>ol]:list-decimal [&>ol]:pl-4 [&>ol]:space-y-1 [&>p]:mt-1.5 [&>p:first-child]:mt-0">
      <slot />
    </div>
    <p class="mt-3 text-xs text-zinc-400 dark:text-zinc-500">Подробности ниже &#x2193;</p>
  </div>
</aside>

<style>
  /* Gradient left border: cyan to violet */
  .tldr-details,
  aside > div.hidden.lg\:block {
    border-image: linear-gradient(to bottom, rgb(6 182 212), rgb(139 92 246)) 1;
  }

  /* Dark mode background */
  :global(.dark) .tldr-details,
  :global(.dark) aside > div.hidden.lg\:block {
    background-color: rgb(6 182 212 / 0.05);
  }
</style>
