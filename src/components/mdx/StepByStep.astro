---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="not-prose my-8">
  {title && (
    <h3 class="mb-6 text-lg font-semibold text-zinc-900 dark:text-zinc-100">
      {title}
    </h3>
  )}

  <div class="steps-container relative pl-10 sm:pl-12">
    <!-- Connecting line -->
    <div class="steps-line absolute bottom-0 left-[15px] top-0 w-px bg-zinc-200 dark:bg-zinc-700 sm:left-[19px]" />

    <div class="steps-content space-y-8 [&>*]:relative">
      <slot />
    </div>
  </div>
</div>

<style>
  /* Each direct child of .steps-content gets a numbered circle */
  .steps-content > :global(*) {
    counter-increment: step-counter;
  }

  .steps-content {
    counter-reset: step-counter;
  }

  .steps-content > :global(*)::before {
    content: counter(step-counter);
    position: absolute;
    left: -40px;
    top: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    z-index: 1;
  }

  @media (min-width: 640px) {
    .steps-content > :global(*)::before {
      left: -48px;
      width: 40px;
      height: 40px;
    }
  }

  /* Light theme step circle */
  .steps-content > :global(*)::before {
    background-color: rgb(236 254 255); /* cyan-50 */
    color: rgb(8 145 178); /* cyan-600 */
    border: 2px solid rgb(165 243 252); /* cyan-200 */
  }

  /* Dark theme step circle */
  :global(.dark) .steps-content > :global(*)::before {
    background-color: rgb(8 145 178 / 0.15); /* cyan-600/15 */
    color: rgb(34 211 238); /* cyan-400 */
    border: 2px solid rgb(8 145 178 / 0.4); /* cyan-600/40 */
  }

  /* Step content text styling */
  .steps-content > :global(*) {
    color: rgb(63 63 70); /* zinc-700 */
  }

  :global(.dark) .steps-content > :global(*) {
    color: rgb(212 212 216); /* zinc-300 */
  }

  /* Style headings inside steps */
  .steps-content :global(h4),
  .steps-content :global(strong:first-child) {
    display: block;
    font-size: 0.9375rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .steps-content :global(h4) {
    color: rgb(24 24 27); /* zinc-900 */
  }

  :global(.dark) .steps-content :global(h4) {
    color: rgb(244 244 245); /* zinc-100 */
  }

  /* Style paragraphs inside steps */
  .steps-content :global(p) {
    font-size: 0.875rem;
    line-height: 1.625;
  }

  .steps-content :global(p + p) {
    margin-top: 0.5rem;
  }

  /* Style inline code inside steps */
  .steps-content :global(code) {
    border-radius: 0.25rem;
    padding: 0.125rem 0.375rem;
    font-size: 0.8125rem;
    background-color: rgb(244 244 245); /* zinc-100 */
  }

  :global(.dark) .steps-content :global(code) {
    background-color: rgb(39 39 42); /* zinc-800 */
  }

  /* Trim the connecting line to the last step circle */
  .steps-line {
    top: 0;
  }
</style>

<script>
  function initSteps() {
    document.querySelectorAll('.steps-container').forEach((container) => {
      const line = container.querySelector('.steps-line') as HTMLElement | null;
      const content = container.querySelector('.steps-content');
      if (!line || !content) return;

      const children = content.children;
      if (children.length === 0) return;

      const lastChild = children[children.length - 1] as HTMLElement;
      const containerRect = container.getBoundingClientRect();
      const lastRect = lastChild.getBoundingClientRect();

      // Line should end at the center of the last step circle
      const lineEnd = lastRect.top - containerRect.top + 16;
      line.style.height = `${lineEnd}px`;
    });
  }

  initSteps();
  document.addEventListener('astro:after-swap', initSteps);

  // Re-calculate on resize and after images load
  window.addEventListener('resize', initSteps);
  window.addEventListener('load', initSteps);
</script>
