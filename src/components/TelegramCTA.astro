---
import { TELEGRAM_CHANNEL_URL, TELEGRAM_CHANNEL_NAME } from '../lib/constants';

interface Props {
  variant?: 'sidebar' | 'inline' | 'bottom';
}

const { variant = 'inline' } = Astro.props;
---

{variant === 'sidebar' && (
  <div class="rounded-xl border border-zinc-200 bg-zinc-50 p-4 dark:border-zinc-800 dark:bg-zinc-900">
    <div class="flex items-center gap-2">
      <svg class="h-5 w-5 text-cyan-500" viewBox="0 0 24 24" fill="currentColor">
        <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
      </svg>
      <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">Telegram</p>
    </div>
    <p class="mt-2 text-xs text-zinc-600 dark:text-zinc-400">
      Больше контента, SQL-задачки и ранний доступ к статьям.
    </p>
    <a
      href={TELEGRAM_CHANNEL_URL}
      target="_blank"
      rel="noopener noreferrer"
      data-ytm="tg-subscribe"
      data-ytm-pos="sidebar"
      class="mt-3 flex w-full items-center justify-center rounded-lg bg-cyan-500 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-cyan-600 dark:bg-cyan-400 dark:text-zinc-950 dark:hover:bg-cyan-300"
    >
      Подписаться
    </a>
  </div>
)}

{variant === 'inline' && (
  <div class="not-prose my-8 rounded-xl border border-cyan-500/20 bg-gradient-to-r from-cyan-500/5 to-transparent p-5 sm:p-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="flex items-center gap-2 font-semibold text-zinc-900 dark:text-zinc-100">
          <svg class="h-5 w-5 text-cyan-500" viewBox="0 0 24 24" fill="currentColor">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
          Нравится контент? Подписывайся на Telegram
        </p>
        <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
          SQL-задачки, кейсы из практики и закулисье аналитики.
        </p>
      </div>
      <a
        href={TELEGRAM_CHANNEL_URL}
        target="_blank"
        rel="noopener noreferrer"
        data-ytm="tg-subscribe"
        data-ytm-pos="inline"
        class="inline-flex shrink-0 items-center justify-center rounded-lg bg-cyan-500 px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-cyan-600 dark:bg-cyan-400 dark:text-zinc-950 dark:hover:bg-cyan-300"
      >
        Подписаться {TELEGRAM_CHANNEL_NAME}
      </a>
    </div>
  </div>
)}

{variant === 'bottom' && (
  <section class="border-t border-zinc-200 bg-gradient-to-b from-cyan-500/5 to-transparent dark:border-zinc-800">
    <div class="mx-auto max-w-3xl px-4 py-12 text-center sm:px-6 sm:py-16">
      <svg class="mx-auto h-10 w-10 text-cyan-500" viewBox="0 0 24 24" fill="currentColor">
        <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
      </svg>
      <h2 class="mt-4 text-2xl font-bold text-zinc-900 dark:text-zinc-100">
        Подпишись на Telegram-канал
      </h2>
      <p class="mt-2 text-zinc-600 dark:text-zinc-400">
        Разборы SQL, аналитические кейсы, шаблоны дашбордов и полезные инструменты. Без воды.
      </p>
      <a
        href={TELEGRAM_CHANNEL_URL}
        target="_blank"
        rel="noopener noreferrer"
        data-ytm="tg-subscribe"
        data-ytm-pos="bottom"
        class="mt-6 inline-flex items-center gap-2 rounded-xl bg-cyan-500 px-8 py-3 text-base font-medium text-white transition-all hover:bg-cyan-600 hover:shadow-lg hover:shadow-cyan-500/25 dark:bg-cyan-400 dark:text-zinc-950 dark:hover:bg-cyan-300"
      >
        Подписаться {TELEGRAM_CHANNEL_NAME}
      </a>
    </div>
  </section>
)}
