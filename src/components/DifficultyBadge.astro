---
type Difficulty = 'beginner' | 'intermediate' | 'advanced';

interface Props {
  difficulty: Difficulty;
  size?: 'sm' | 'md';
}

const { difficulty, size = 'sm' } = Astro.props;

const config: Record<Difficulty, { label: string; color: string; dotColor: string }> = {
  beginner: {
    label: 'Новичок',
    color: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
    dotColor: 'bg-emerald-500',
  },
  intermediate: {
    label: 'Практик',
    color: 'bg-cyan-500/10 text-cyan-400 border-cyan-500/20',
    dotColor: 'bg-cyan-500',
  },
  advanced: {
    label: 'Продвинутый',
    color: 'bg-violet-500/10 text-violet-400 border-violet-500/20',
    dotColor: 'bg-violet-500',
  },
};

const { label, color, dotColor } = config[difficulty];
const sizeClasses = size === 'sm' ? 'px-2 py-0.5 text-xs' : 'px-3 py-1 text-sm';
---

<span class={`inline-flex items-center gap-1.5 rounded-full border font-medium ${sizeClasses} ${color}`}>
  <span class={`inline-block h-1.5 w-1.5 rounded-full ${dotColor}`}></span>
  {label}
</span>
