---
import ThemeToggle from './ThemeToggle.astro';
import SearchDialog from './SearchDialog.astro';
import { NAV_LINKS, SITE_TITLE } from '../lib/constants';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 w-full border-b border-zinc-200 bg-white/80 backdrop-blur-lg dark:border-zinc-800 dark:bg-zinc-950/80">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 text-zinc-900 transition-colors hover:text-cyan-500 dark:text-zinc-100 dark:hover:text-cyan-400" data-ytm="logo">
      <svg class="h-7 w-7" viewBox="0 0 32 32" fill="none">
        <rect width="32" height="32" rx="6" fill="currentColor" opacity="0.1" />
        <path d="M6 22 L10 10 L14 18 L18 8 L22 16 L26 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none" class="text-cyan-500 dark:text-cyan-400" />
      </svg>
      <span class="text-lg font-bold tracking-tight">{SITE_TITLE}</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden items-center gap-1 md:flex">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-lg px-3 py-2 text-sm font-medium transition-colors',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'bg-zinc-100 text-zinc-900 dark:bg-zinc-800 dark:text-zinc-100'
              : 'text-zinc-600 hover:bg-zinc-100 hover:text-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-100',
          ]}
        >
          {link.label}
        </a>
      ))}
      <button
        id="search-trigger"
        type="button"
        data-ytm="search"
        class="inline-flex items-center gap-2 rounded-lg border border-zinc-200 px-3 py-1.5 text-sm text-zinc-500 transition-colors hover:border-zinc-300 hover:text-zinc-700 dark:border-zinc-700 dark:text-zinc-400 dark:hover:border-zinc-600 dark:hover:text-zinc-300"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <span>Поиск</span>
        <kbd class="ml-2 rounded border border-zinc-300 bg-zinc-100 px-1.5 py-0.5 text-xs font-medium dark:border-zinc-600 dark:bg-zinc-800">⌘K</kbd>
      </button>
      <div class="ml-2">
        <ThemeToggle />
      </div>
    </nav>

    <!-- Mobile menu button -->
    <div class="flex items-center gap-2 md:hidden">
      <button
        id="mobile-search-btn"
        type="button"
        aria-label="Поиск"
        class="flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-200 text-zinc-600 transition-colors hover:bg-zinc-100 dark:border-zinc-700 dark:text-zinc-400 dark:hover:bg-zinc-800"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Открыть меню"
        class="flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-200 text-zinc-600 transition-colors hover:bg-zinc-100 dark:border-zinc-700 dark:text-zinc-400 dark:hover:bg-zinc-800"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <nav
    id="mobile-menu"
    class="hidden border-t border-zinc-200 bg-white px-4 pb-4 pt-2 dark:border-zinc-800 dark:bg-zinc-950 md:hidden"
  >
    {NAV_LINKS.map((link) => (
      <a
        href={link.href}
        class:list={[
          'block rounded-lg px-3 py-2.5 text-sm font-medium transition-colors',
          currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
            ? 'bg-zinc-100 text-zinc-900 dark:bg-zinc-800 dark:text-zinc-100'
            : 'text-zinc-600 hover:bg-zinc-100 dark:text-zinc-400 dark:hover:bg-zinc-800',
        ]}
      >
        {link.label}
      </a>
    ))}
  </nav>
</header>

<SearchDialog />

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
  }
  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
