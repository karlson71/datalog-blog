---
import { getCollection } from 'astro:content';
import { CATEGORIES, type CategoryKey } from '../lib/constants';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const searchData = posts.map((p) => ({
  id: p.id,
  title: p.data.title,
  description: p.data.description,
  category: p.data.category,
  categoryLabel: CATEGORIES[p.data.category as CategoryKey].label,
  tags: p.data.tags,
}));
---

<!-- Search dialog -->
<dialog
  id="search-dialog"
  class="m-0 mx-auto mt-[15vh] w-full max-w-xl rounded-2xl border border-zinc-200 bg-white p-0 shadow-2xl backdrop:bg-zinc-950/50 backdrop:backdrop-blur-sm dark:border-zinc-700 dark:bg-zinc-900"
>
  <div class="p-4">
    <div class="flex items-center gap-3 border-b border-zinc-200 pb-3 dark:border-zinc-700">
      <svg class="h-5 w-5 shrink-0 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input
        id="search-input"
        type="text"
        placeholder="Поиск статей..."
        autocomplete="off"
        class="w-full bg-transparent text-base text-zinc-900 placeholder-zinc-400 outline-none dark:text-zinc-100"
      />
      <kbd class="shrink-0 rounded border border-zinc-300 bg-zinc-100 px-1.5 py-0.5 text-xs text-zinc-500 dark:border-zinc-600 dark:bg-zinc-800 dark:text-zinc-400">Esc</kbd>
    </div>

    <div id="search-results" class="mt-3 max-h-[50vh] overflow-y-auto">
      <p id="search-empty" class="hidden py-8 text-center text-sm text-zinc-500 dark:text-zinc-400">
        Ничего не найдено
      </p>
      <p id="search-hint" class="py-8 text-center text-sm text-zinc-500 dark:text-zinc-400">
        Начни вводить для поиска...
      </p>
      <ul id="search-list" class="space-y-1"></ul>
    </div>
  </div>
</dialog>

<script define:vars={{ searchData }}>
  function initSearch() {
    const dialog = document.getElementById('search-dialog');
    const trigger = document.getElementById('search-trigger');
    const input = document.getElementById('search-input');
    const list = document.getElementById('search-list');
    const empty = document.getElementById('search-empty');
    const hint = document.getElementById('search-hint');
    if (!dialog || !input || !list || !empty || !hint) return;

    let selectedIndex = -1;

    function openSearch() {
      dialog.showModal();
      input.value = '';
      input.focus();
      list.innerHTML = '';
      empty.classList.add('hidden');
      hint.classList.remove('hidden');
      selectedIndex = -1;
    }

    function closeSearch() {
      dialog.close();
    }

    function highlightMatch(text, query) {
      if (!query) return text;
      const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
      return text.replace(regex, '<mark class="bg-cyan-500/20 text-cyan-600 dark:text-cyan-400 rounded px-0.5">$1</mark>');
    }

    function search(query) {
      const q = query.toLowerCase().trim();
      if (!q) {
        list.innerHTML = '';
        empty.classList.add('hidden');
        hint.classList.remove('hidden');
        selectedIndex = -1;
        return;
      }

      hint.classList.add('hidden');

      const results = searchData.filter((post) => {
        return (
          post.title.toLowerCase().includes(q) ||
          post.description.toLowerCase().includes(q) ||
          post.categoryLabel.toLowerCase().includes(q) ||
          post.tags.some((t) => t.toLowerCase().includes(q))
        );
      });

      if (results.length === 0) {
        list.innerHTML = '';
        empty.classList.remove('hidden');
        selectedIndex = -1;
        return;
      }

      empty.classList.add('hidden');
      selectedIndex = 0;

      list.innerHTML = results
        .map(
          (post, i) => `
          <li>
            <a
              href="/blog/${post.id}/"
              class="search-result flex flex-col gap-1 rounded-xl px-4 py-3 transition-colors hover:bg-zinc-100 dark:hover:bg-zinc-800 ${i === 0 ? 'bg-zinc-100 dark:bg-zinc-800' : ''}"
              data-index="${i}"
            >
              <div class="flex items-center gap-2">
                <span class="inline-flex rounded-full border border-current/20 px-2 py-0.5 text-xs font-medium text-cyan-600 dark:text-cyan-400">${post.categoryLabel}</span>
                <span class="text-base font-medium text-zinc-900 dark:text-zinc-100">${highlightMatch(post.title, query)}</span>
              </div>
              <span class="text-sm text-zinc-500 dark:text-zinc-400">${highlightMatch(post.description, query)}</span>
            </a>
          </li>`
        )
        .join('');
    }

    function updateSelection() {
      const items = list.querySelectorAll('.search-result');
      items.forEach((item, i) => {
        if (i === selectedIndex) {
          item.classList.add('bg-zinc-100', 'dark:bg-zinc-800');
          item.scrollIntoView({ block: 'nearest' });
        } else {
          item.classList.remove('bg-zinc-100', 'dark:bg-zinc-800');
        }
      });
    }

    // Events
    trigger?.addEventListener('click', openSearch);
    document.getElementById('mobile-search-btn')?.addEventListener('click', openSearch);

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        openSearch();
      }
    });

    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) closeSearch();
    });

    input.addEventListener('input', () => search(input.value));

    input.addEventListener('keydown', (e) => {
      const items = list.querySelectorAll('.search-result');
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        selectedIndex = Math.min(selectedIndex + 1, items.length - 1);
        updateSelection();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        selectedIndex = Math.max(selectedIndex - 1, 0);
        updateSelection();
      } else if (e.key === 'Enter' && selectedIndex >= 0 && items[selectedIndex]) {
        e.preventDefault();
        items[selectedIndex].click();
      }
    });
  }

  initSearch();
  document.addEventListener('astro:after-swap', initSearch);
</script>
