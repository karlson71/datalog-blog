---
import BaseLayout from './BaseLayout.astro';
import PostMeta from '../components/PostMeta.astro';
import BookmarkButton from '../components/BookmarkButton.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import TelegramCTA from '../components/TelegramCTA.astro';
import ShareButtons from '../components/ShareButtons.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import { getCollection } from 'astro:content';
import { getRelatedPosts } from '../lib/utils';
import { SITE_URL } from '../lib/constants';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  headings: { depth: number; slug: string; text: string }[];
  minutesRead?: string;
}

const { post, headings, minutesRead } = Astro.props;
const { title, description, pubDate, updatedDate, category } = post.data;

const allPosts = await getCollection('blog');
const relatedPosts = getRelatedPosts(post, allPosts);
const postUrl = `${SITE_URL}/blog/${post.id}/`;
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  seoType="blogPost"
  slug={post.id}
>
  <ReadingProgress />

  <article class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12">
    <!-- Article header -->
    <header class="mx-auto max-w-3xl">
      <div class="flex items-start justify-between gap-4">
        <PostMeta pubDate={pubDate} minutesRead={minutesRead} category={category} />
        <BookmarkButton slug={post.id} title={title} description={description} category={category} />
      </div>
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 sm:text-4xl lg:text-5xl">
        {title}
      </h1>
      <p class="mt-4 text-lg text-zinc-600 dark:text-zinc-400">
        {description}
      </p>
      {updatedDate && (
        <p class="mt-3 text-sm text-zinc-500 dark:text-zinc-500">
          Обновлено: {new Intl.DateTimeFormat('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' }).format(updatedDate)}
        </p>
      )}
    </header>

    <!-- Mobile TOC -->
    <div class="mx-auto mt-8 max-w-3xl lg:hidden">
      <TableOfContents headings={headings} />
    </div>

    <!-- Content + sidebar -->
    <div class="relative mt-8 lg:mt-12 lg:grid lg:grid-cols-[1fr_220px] lg:gap-12 xl:grid-cols-[1fr_250px]">
      <!-- Main content -->
      <div class="prose prose-zinc mx-auto max-w-3xl dark:prose-invert prose-headings:scroll-mt-20 prose-a:text-cyan-600 dark:prose-a:text-cyan-400 prose-pre:rounded-xl prose-img:rounded-xl lg:mx-0">
        <slot />
        <TelegramCTA variant="inline" />
      </div>

      <!-- Desktop sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-6">
          <TableOfContents headings={headings} />
          <TelegramCTA variant="sidebar" />
        </div>
      </aside>
    </div>

    <!-- Post footer -->
    <div class="mx-auto mt-12 max-w-3xl border-t border-zinc-200 pt-6 dark:border-zinc-800">
      <ShareButtons title={title} url={postUrl} />
    </div>

    <!-- Related posts -->
    <div class="mx-auto max-w-6xl">
      <RelatedPosts posts={relatedPosts} />
    </div>
  </article>

  <TelegramCTA variant="bottom" />
</BaseLayout>
