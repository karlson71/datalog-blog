---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import KeyboardNav from '../components/KeyboardNav.astro';
import SEO from '../components/SEO.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  seoType?: 'website' | 'blogPost';
  slug?: string;
  readingTime?: string;
}

const {
  title,
  description,
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  seoType = 'website',
  slug,
  readingTime,
} = Astro.props;
---

<!doctype html>
<html lang="ru" class="dark">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      slug={slug}
    />
    <SEO
      type={seoType}
      title={title}
      description={description}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      image={image}
      slug={slug}
      readingTime={readingTime}
    />
    <ClientRouter />
  </head>
  <body class="flex min-h-screen flex-col bg-white text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <BackToTop />
    <KeyboardNav />

    <!-- Heading anchor links + scroll reveal -->
    <script>
      function initHeadingAnchors() {
        document.querySelectorAll('.prose h2[id], .prose h3[id]').forEach((heading) => {
          if (heading.querySelector('.heading-anchor')) return;
          const anchor = document.createElement('a');
          anchor.className = 'heading-anchor';
          anchor.href = `#${heading.id}`;
          anchor.textContent = '#';
          anchor.title = 'Скопировать ссылку';
          anchor.addEventListener('click', (e) => {
            e.preventDefault();
            const url = `${window.location.origin}${window.location.pathname}#${heading.id}`;
            navigator.clipboard.writeText(url).then(() => {
              anchor.textContent = '✓';
              setTimeout(() => { anchor.textContent = '#'; }, 1500);
            });
          });
          heading.prepend(anchor);
        });
      }

      function initScrollReveal() {
        const elements = document.querySelectorAll('.scroll-reveal');
        if (elements.length === 0) return;
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );
        elements.forEach((el) => observer.observe(el));
      }

      initHeadingAnchors();
      initScrollReveal();
      document.addEventListener('astro:after-swap', () => {
        initHeadingAnchors();
        initScrollReveal();
      });
    </script>
  </body>
</html>
